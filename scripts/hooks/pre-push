#!/usr/bin/env bash
# pre-push hook — 실제 interop DLL 로 전체 빌드 후 BepInEx/plugins/ 에 배포합니다.
# 설치: scripts/Install-Hooks.ps1 실행

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BEPINEX_PATH="${BEPINEX_PATH:-D:/SteamLibrary/steamapps/common/Bloodshed/BepInEx}"
PLUGINS_DIR="$BEPINEX_PATH/plugins"

# interop DLL 존재 여부 확인
if [ ! -f "$BEPINEX_PATH/interop/Assembly-CSharp.dll" ]; then
    echo "[pre-push] ⚠ BepInEx/interop/ 가 없음 — 게임을 한 번 실행해주세요."
    echo "[pre-push]   실제 빌드 검증 건너뜀 (stub 빌드는 통과됨)."
    exit 0
fi

echo "[pre-push] 실제 빌드 및 배포 중..."

dotnet build "$REPO_ROOT" -c Release \
    "-p:BepInExPath=$BEPINEX_PATH" \
    --no-incremental \
    -v quiet

DLL="$REPO_ROOT/bin/Release/net6.0/BloodshedModToolkit.dll"

if [ ! -f "$DLL" ]; then
    echo "[pre-push] 빌드 결과물을 찾을 수 없습니다: $DLL"
    exit 1
fi

# 게임이 실행 중이 아닐 때 자동 배포
if [ -d "$PLUGINS_DIR" ]; then
    cp "$DLL" "$PLUGINS_DIR/"
    echo "[pre-push] 배포 완료: $PLUGINS_DIR/BloodshedModToolkit.dll"
fi

echo "[pre-push] OK"
exit 0
