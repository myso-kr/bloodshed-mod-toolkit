#!/usr/bin/env bash
# pre-push hook
# 1) 실제 interop DLL 로 전체 빌드
# 2) BepInEx/plugins/ 로컬 배포
# 3) GitHub Release 자동 생성 (Publish-Release.ps1 -SkipBuild)
# 설치: scripts/Install-Hooks.ps1 실행

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BEPINEX_PATH="${BEPINEX_PATH:-D:/SteamLibrary/steamapps/common/Bloodshed/BepInEx}"
PLUGINS_DIR="$BEPINEX_PATH/plugins"
DLL="$REPO_ROOT/bin/Release/net6.0/BloodshedModToolkit.dll"

# interop DLL 없으면 게임 미실행 상태 — 전체 과정 건너뜀
if [ ! -f "$BEPINEX_PATH/interop/Assembly-CSharp.dll" ]; then
    echo "[pre-push] ⚠ BepInEx/interop/ 없음 — 게임을 한 번 실행한 뒤 다시 push하세요."
    echo "[pre-push]   로컬 배포 및 GitHub Release 생략."
    exit 0
fi

# ── 1. 실제 빌드 ─────────────────────────────────────────────────────────────
echo "[pre-push] 빌드 중..."
dotnet build "$REPO_ROOT" -c Release \
    "-p:BepInExPath=$BEPINEX_PATH" \
    --no-incremental \
    -v minimal

# ── 2. 로컬 배포 ─────────────────────────────────────────────────────────────
if [ -d "$PLUGINS_DIR" ]; then
    cp "$DLL" "$PLUGINS_DIR/"
    echo "[pre-push] 로컬 배포: $PLUGINS_DIR/BloodshedModToolkit.dll"
fi

# ── 3. GitHub Release ────────────────────────────────────────────────────────
echo "[pre-push] GitHub Release 생성 중..."
pwsh -NonInteractive -File "$REPO_ROOT/scripts/Publish-Release.ps1" \
    -SkipBuild \
    -NoBrowser

echo "[pre-push] OK"
exit 0
